        custom float[] lod:Heuristic:graphics:distance:maxThresholds = [10, 22]
        custom float[] lod:Heuristic:graphics:distance:minThresholds = [8, 20]
        custom rel lod:lodItems = [
            </World/Object/High>,
            </World/Object/Mid>,
            </World/Object/Low>,
        ]

        def Sphere "High" (
            apiSchemas = ["LodItemAPI"]
        )
        {
            color3f[] primvars:displayColor = [(0.9, 0.15, 0.1)]
            double radius = 0.8
            double3 xformOp:translate = (0, 0.8, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Cube "Mid" (
            apiSchemas = ["LodItemAPI"]
        )
