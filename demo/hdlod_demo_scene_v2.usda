            color3f[] primvars:displayColor = [(0.1, 0.8, 0.2)]
            double size = 1.3
            double3 xformOp:translate = (0, 0.65, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Cube "Low" (
            apiSchemas = ["LodItemAPI"]
        )
